(105,'Rahul',50000,2,'2026-06-10');

SELECT * FROM Employee ;

1. Find Highest Salary :-
SELECT MAX(salary) AS highest_salary FROM Employee;
Output:
      80000      

2. Department Wise Employee Count :-
SELECT dept_id, COUNT(*) AS employee_count FROM Employee GROUP BY dept_id;
Output:
      dept_id  employee_count
          1          1
          2          3

3. Find Second Highest Salary :-
SELECT MAX(sal) AS Second_highest FROM Employee WHERE SAL < ( SELECT MAX(sal) FROM Employee);
Output:
        Second_highest 
        70000

4. Employees whose salary > department average salary :-
SELECT e.emp_name,salary,e.dept_name FROM  Employee e WHERE salary > (SELECT AVG(salary) Department e.emp_id = e.dept_id );
Output:
    emp_name	salary	dept_id
        Neha	70000	103
        Priya	65000	102

5. Inner join :-
SELECT e.emp_name, d.dept_name FROM Employee e INNER JOIN Department d ON e.dept_id = d.dept_id;
Output:
    emp_name	dept_name
      Rahul	   IT
      Priya	   HR
      Neha	   Sales
5 .Left Join :-
SELECT e.emp_name, d.dept_name FROM Employee e LEFT JOIN Department d ON e.dept_id = d.dept_id;
Output:
  emp_name	dept_name
    Rahul	  IT
    Priya	  HR
    Neha	  NULL
6.Group By with Having :-
SELECT dept_id, COUNT(*) AS employee_count FROM Employee GROUP BY dept_id HAVING COUNT(*) > 2;
Output:
   dept_id  employee_count 
     1              3              
     2              5              

7.Employees hired in last 6 months :-
SELECT * FROM Employee WHERE hire_date >= DATE_SUB(CURDATE(), INTERVAL 6 MONTH);
